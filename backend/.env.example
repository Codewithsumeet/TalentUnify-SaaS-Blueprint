# Document Parsing
LLAMA_CLOUD_API_KEY=llx-...

# LLM
ANTHROPIC_API_KEY=sk-ant-...

# Embeddings
# IMPORTANT: DATABASE_URL must start with postgresql+asyncpg:// for FastAPI async engine
# The sync Celery engine strips +asyncpg automatically via get_sync_db_url()
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# Pinecone — TWO separate indexes (dimension mismatch between OpenAI and MiniLM)
PINECONE_API_KEY=...
PINECONE_ENV=us-east-1
PINECONE_INDEX_MAIN=candidates
PINECONE_INDEX_LOCAL=candidates-local

# Task Queue
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Database
# MUST use postgresql+asyncpg:// schema. Sync URL is derived automatically.
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/talentflow

# Gmail OAuth
GMAIL_CLIENT_ID=...
GMAIL_CLIENT_SECRET=...
GMAIL_REDIRECT_URI=http://localhost:8000/integration/gmail/callback

# Calendly
CALENDLY_PERSONAL_ACCESS_TOKEN=
CALENDLY_ORGANIZATION_URI=
CALENDLY_USER_URI=
CALENDLY_MOCK_MODE=true

# Demo
DEMO_MODE=false
